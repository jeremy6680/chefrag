# ==============================================================================
# ChefRAG — Environment variables template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ==============================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- App authentication ---
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
APP_PASSWORD=$2b$12$your_bcrypt_hash_here

# --- UI ---
# Default language for the interface: "fr" or "en"
APP_LANGUAGE_DEFAULT=fr

# --- ChromaDB ---
# Dev local : CHROMA_HOST=localhost
# Docker / prod : CHROMA_HOST=chefrag-chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000

# --- DuckDB ---
# Path inside the container (mounted volume)
DUCKDB_PATH=/app/storage/duckdb/chefrag.duckdb

# --- Logging ---
# INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Airflow (added in Step 6 — leave empty for now) ---
# AIRFLOW_ADMIN_USER=admin
# AIRFLOW_ADMIN_PASSWORD=your_airflow_password_here
